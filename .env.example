# Shared environment variables for local development
# Copy to `.env` in the repo root if you prefer exporting once.

POSTGRES_DB=<your-database-name>
POSTGRES_USER=<postgres-user>
POSTGRES_PASSWORD=<your-password>
POSTGRES_PORT=<your-port>
POSTGRES_HOST=<your-host>

# Optional: when set, `pnpm db:seed` imports a plain PostgreSQL prod dump
# into the current dev schema instead of generating demo data.
# PROD_DB_DUMP_PATH=/absolute/path/to/plain-pg-dump.sql

# Meals Web
# Internal origin used by Next.js rewrites (server-side) during dev/build
# For local Docker dev this could be http://meals-api:4000; for bare-metal dev http://localhost:4000
MEALS_API_INTERNAL_ORIGIN=http://localhost:4000

# Public URL that the browser uses (client-side). In prod we keep it as '/api' (Next proxy), locally you can point to http://localhost:4000 or keep '/api'
NEXT_PUBLIC_API_URL=/api
