# Base URL the browser will call (client-side). In prod we use '/api' so Next proxies to the backend.
NEXT_PUBLIC_API_URL=/api

# Internal origin for server-side rewrites (Next). Useful in Docker or dev.
# Example Docker: http://meals-api:4000  |  Example bare dev: http://localhost:4000
MEALS_API_INTERNAL_ORIGIN=http://localhost:4000

# Demo mode: run the whole app self-contained against an embedded in-memory
# database (no API server, Postgres, or login). Used for the public demo
# deployment. See "Demo mode" in the root README.
# NEXT_PUBLIC_DEMO_MODE=1
