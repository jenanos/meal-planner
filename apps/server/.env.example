DATABASE_URL="postgresql://postgres:<your-password>@<db-host>:<db-port>/<db-name>"
AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# Optional. Set to a parent domain (with leading dot) to issue better-auth
# session cookies that span subdomains. Required in production for the MCP
# server's OAuth provider on meals-mcp.<domain> to validate the same login
# session as meals.<domain>. Leave unset in local dev.
# Example: BETTER_AUTH_COOKIE_DOMAIN=.jenanos.xyz
BETTER_AUTH_COOKIE_DOMAIN=

# Admin user email – seeded into the allowlist on first run.
# In production, set this to the primary admin's email address.
ADMIN_EMAIL=

# Optional bootstrap household.
# Comma-separated email lists; OWNER entries win if the same email is present
# in both lists. If only BOOTSTRAP_HOUSEHOLD_NAME + ADMIN_EMAIL are set, the
# admin email is used as the initial owner automatically.
BOOTSTRAP_HOUSEHOLD_NAME=
BOOTSTRAP_HOUSEHOLD_OWNER_EMAILS=
BOOTSTRAP_HOUSEHOLD_MEMBER_EMAILS=

# Magic-link email delivery (Resend)
RESEND_API_KEY=
EMAIL_FROM="Butta <login@example.com>"

# OAuth providers (optional – only enabled when set)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=

# Comma-separated list of allowed origins for CORS and auth.
# Include the MCP host so magic-link callbacks back to /oauth/authorize
# are accepted by better-auth.
AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://mcp.yourdomain.com

# Service-to-service API key for MCP server.
# Must match MCP_API_KEY in apps/mcp-server/.env.
MCP_API_KEY=

PORT=4000
NODE_ENV=development
