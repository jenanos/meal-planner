DATABASE_URL="postgresql://postgres:<your-password>@<db-host>:<db-port>/<db-name>"

# OAuth providers (optional – only enabled when set)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=

# Comma-separated list of allowed origins for CORS and auth
AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com

PORT=4000
NODE_ENV=development
