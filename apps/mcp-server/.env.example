# Internal origin for the meals API server
MEALS_API_INTERNAL_ORIGIN=http://localhost:4000

# Required even though the MCP server never queries Postgres directly.
# Importing @repo/api transitively loads @repo/database, whose client
# module validates DATABASE_URL at module load and throws if it is unset
# (the Prisma client is constructed only after that check passes).
# Point this at the same Postgres instance as the meals API; the
# connection is lazy and never opened in practice.
DATABASE_URL=

# Shared secret for service-to-service auth between mcp-server and meals-api.
# Must match MCP_API_KEY in apps/server/.env.
# Generate with: openssl rand -base64 32
MCP_API_KEY=

# Optional bearer token required on incoming /mcp requests.
# When set, clients must send `Authorization: Bearer <token>`. When unset,
# /mcp accepts unauthenticated requests and you must rely on an external
# gate (Cloudflare Access, mTLS, VPN, …).
# Generate with: openssl rand -base64 32
MCP_BEARER_TOKEN=

# Port for the MCP server
PORT=5050

# Optional: comma-separated list of Host headers allowed by the server for
# DNS rebinding protection. Example:
# MCP_ALLOWED_HOSTS=meals-mcp.example.com,meals-mcp:5050,localhost:5050
MCP_ALLOWED_HOSTS=
