# Internal origin for the meals API server. Used both for forwarded tRPC
# calls and for validating better-auth sessions during the OAuth login flow
# (the MCP server calls `${MEALS_API_INTERNAL_ORIGIN}/auth/get-session`).
MEALS_API_INTERNAL_ORIGIN=http://localhost:4000

# Required for OAuth provider state (clients, codes, refresh tokens).
# @repo/database also validates DATABASE_URL at module load.
# Point this at the same Postgres instance as the meals API.
DATABASE_URL=

# Shared secret for service-to-service auth between mcp-server and meals-api.
# Must match MCP_API_KEY in apps/server/.env.
# Generate with: openssl rand -base64 32
MCP_API_KEY=

# ── OAuth 2.1 provider ──────────────────────────────────────────
# The MCP server hosts its own OAuth 2.1 authorization server (PKCE,
# Dynamic Client Registration). All three of the following are required.

# Public origin of this MCP server – used as the issuer in tokens and in
# /.well-known metadata. No trailing slash.
MCP_OAUTH_ISSUER=https://meals-mcp.example.com

# HMAC secret for signing JWT access tokens. Generate with:
#   openssl rand -base64 64
MCP_OAUTH_SIGNING_SECRET=

# Public URL of the meals web app's login page. The /oauth/authorize
# endpoint redirects unauthenticated users here with `?callbackUrl=…`.
# After successful sign-in, the login page sends the user back to
# /oauth/authorize, which then issues an authorization code.
MCP_OAUTH_LOGIN_URL=https://meals.example.com/login

# Optional. Access token lifetime in seconds (default 3600 = 1h).
MCP_OAUTH_ACCESS_TOKEN_TTL=3600

# Optional. Refresh token lifetime in seconds (default 30 days).
MCP_OAUTH_REFRESH_TOKEN_TTL=2592000

# Port for the MCP server
PORT=5050

# Optional: comma-separated list of Host headers allowed by the server for
# DNS rebinding protection. Example:
# MCP_ALLOWED_HOSTS=meals-mcp.example.com,meals-mcp:5050,localhost:5050
MCP_ALLOWED_HOSTS=
